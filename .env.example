# EllipticZero environment template
# Copy this file to `.env` only if you need local overrides.
# The project works in mock mode without any external API keys.

# ---------------------------------------------------------------------------
# 1. Runtime profile
# ---------------------------------------------------------------------------

# Optional: explicit path to the YAML settings file
ELLIPTICZERO_CONFIG_PATH=configs/settings.yaml

# Interface language
ELLIPTICZERO_UI_LANGUAGE=en

# Logging
ELLIPTICZERO_LOG_LEVEL=WARNING

# ---------------------------------------------------------------------------
# 2. Shared LLM routing
# ---------------------------------------------------------------------------

# Runtime-supported provider names today:
# - mock
# - openai
# - openrouter
# - gemini
# - anthropic

# Optional shorthand for the shared default provider
ELLIPTICZERO_LLM_PROVIDER=mock

# Shared default route used by every agent unless you override a specific role
ELLIPTICZERO_LLM_DEFAULT_PROVIDER=mock
ELLIPTICZERO_LLM_DEFAULT_MODEL=mock-default

# Optional fallback route
ELLIPTICZERO_LLM_FALLBACK_PROVIDER=
ELLIPTICZERO_LLM_FALLBACK_MODEL=

# Request budgets
ELLIPTICZERO_LLM_TIMEOUT_SECONDS=60
ELLIPTICZERO_LLM_MAX_REQUEST_TOKENS=2048
ELLIPTICZERO_LLM_MAX_TOTAL_REQUESTS_PER_SESSION=16

# ---------------------------------------------------------------------------
# 3. Provider API keys
# ---------------------------------------------------------------------------

# Active providers in the current runtime:
OPENAI_API_KEY=
OPENROUTER_API_KEY=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=

# Example shared-provider setup:
# OPENAI_API_KEY=your_key_here
# ELLIPTICZERO_LLM_DEFAULT_PROVIDER=openai
# ELLIPTICZERO_LLM_DEFAULT_MODEL=<openai-model>

# Example Google/Gemini shared setup:
# GEMINI_API_KEY=your_key_here
# ELLIPTICZERO_LLM_DEFAULT_PROVIDER=gemini
# ELLIPTICZERO_LLM_DEFAULT_MODEL=<gemini-model>

# Example OpenRouter shared setup:
# OPENROUTER_API_KEY=your_key_here
# ELLIPTICZERO_LLM_DEFAULT_PROVIDER=openrouter
# ELLIPTICZERO_LLM_DEFAULT_MODEL=<openrouter-model-id>
# For bounded direct smoke checks, `openrouter/auto` is a safe default unless
# you intentionally want to pin a specific OpenRouter model id.
#
# OpenRouter also exposes some `:free` model variants for bounded smoke checks,
# but those runs remain subject to OpenRouter rate and daily limits.

# Example Anthropic/Claude shared setup:
# ANTHROPIC_API_KEY=your_key_here
# ELLIPTICZERO_LLM_DEFAULT_PROVIDER=anthropic
# ELLIPTICZERO_LLM_DEFAULT_MODEL=<anthropic-model>

# ---------------------------------------------------------------------------
# 4. Optional per-agent overrides
# ---------------------------------------------------------------------------

# Leave these empty to keep one shared provider/model for all roles.
# Set them only if you intentionally want a mixed routing setup.

# math_agent
ELLIPTICZERO_AGENT_MATH_AGENT_PROVIDER=
ELLIPTICZERO_AGENT_MATH_AGENT_MODEL=

# cryptography_agent
ELLIPTICZERO_AGENT_CRYPTOGRAPHY_AGENT_PROVIDER=
ELLIPTICZERO_AGENT_CRYPTOGRAPHY_AGENT_MODEL=

# strategy_agent
ELLIPTICZERO_AGENT_STRATEGY_AGENT_PROVIDER=
ELLIPTICZERO_AGENT_STRATEGY_AGENT_MODEL=

# hypothesis_agent
ELLIPTICZERO_AGENT_HYPOTHESIS_AGENT_PROVIDER=
ELLIPTICZERO_AGENT_HYPOTHESIS_AGENT_MODEL=

# critic_agent
ELLIPTICZERO_AGENT_CRITIC_AGENT_PROVIDER=
ELLIPTICZERO_AGENT_CRITIC_AGENT_MODEL=

# report_agent
ELLIPTICZERO_AGENT_REPORT_AGENT_PROVIDER=
ELLIPTICZERO_AGENT_REPORT_AGENT_MODEL=

# Example mixed setup:
# ELLIPTICZERO_LLM_DEFAULT_PROVIDER=openai
# ELLIPTICZERO_LLM_DEFAULT_MODEL=<shared-model>
# ELLIPTICZERO_AGENT_MATH_AGENT_MODEL=<math-model>
# ELLIPTICZERO_AGENT_REPORT_AGENT_MODEL=<report-model>

# ---------------------------------------------------------------------------
# 5. Research session behavior
# ---------------------------------------------------------------------------

ELLIPTICZERO_RESEARCH_MODE=standard
ELLIPTICZERO_DEFAULT_EXPLORATION_PROFILE=cautious
ELLIPTICZERO_MAX_HYPOTHESES=2
ELLIPTICZERO_TOOL_TIMEOUT_SECONDS=30

ELLIPTICZERO_MAX_EXPLORATORY_BRANCHES=2
ELLIPTICZERO_MAX_EXPLORATORY_ROUNDS=2
ELLIPTICZERO_MAX_JOBS_PER_SESSION=4

ELLIPTICZERO_AGGRESSIVE_MAX_EXPLORATORY_BRANCHES=3
ELLIPTICZERO_AGGRESSIVE_MAX_EXPLORATORY_ROUNDS=3
ELLIPTICZERO_AGGRESSIVE_MAX_JOBS_PER_SESSION=6
ELLIPTICZERO_REQUIRE_MANUAL_REVIEW_FOR_EXPLORATORY=true

# ---------------------------------------------------------------------------
# 6. Local storage
# ---------------------------------------------------------------------------

ELLIPTICZERO_STORAGE_SESSIONS_DIR=artifacts/sessions
ELLIPTICZERO_STORAGE_TRACES_DIR=artifacts/traces

# ---------------------------------------------------------------------------
# 7. Local research adapters
# ---------------------------------------------------------------------------

# These control bounded local runners used only by approved tools.
ELLIPTICZERO_SYMPY_ENABLED=true
ELLIPTICZERO_PROPERTY_ENABLED=true
ELLIPTICZERO_PROPERTY_MAX_EXAMPLES=24
ELLIPTICZERO_FUZZ_ENABLED=true
ELLIPTICZERO_FUZZ_MAX_MUTATIONS=12
ELLIPTICZERO_FUZZ_SEED=1337
ELLIPTICZERO_FORMAL_ENABLED=true
ELLIPTICZERO_FORMAL_BACKEND=z3
ELLIPTICZERO_FORMAL_TIMEOUT_SECONDS=5
ELLIPTICZERO_ECC_TESTBEDS_ENABLED=true
ELLIPTICZERO_SMART_CONTRACT_TESTBEDS_ENABLED=true
ELLIPTICZERO_SMART_CONTRACT_COMPILE_ENABLED=true
ELLIPTICZERO_MANAGED_SOLC_DIR=.ellipticzero/tooling/solcx
ELLIPTICZERO_MANAGED_SOLC_VERSION=0.8.20
ELLIPTICZERO_SOLC_BINARY=solc
ELLIPTICZERO_SOLCJS_BINARY=solcjs
ELLIPTICZERO_SMART_CONTRACT_COMPILE_TIMEOUT_SECONDS=12
ELLIPTICZERO_SLITHER_ENABLED=true
ELLIPTICZERO_SLITHER_BINARY=slither
ELLIPTICZERO_SLITHER_TIMEOUT_SECONDS=45
ELLIPTICZERO_ECHIDNA_ENABLED=true
ELLIPTICZERO_ECHIDNA_BINARY=echidna
ELLIPTICZERO_ECHIDNA_TIMEOUT_SECONDS=45
ELLIPTICZERO_ECHIDNA_TEST_LIMIT=128
ELLIPTICZERO_ECHIDNA_SEQ_LEN=16
ELLIPTICZERO_FOUNDRY_ENABLED=true
ELLIPTICZERO_FORGE_BINARY=forge
ELLIPTICZERO_FOUNDRY_TIMEOUT_SECONDS=45

# The setup scripts can provision a project-managed Solidity compiler into
# .ellipticzero/tooling/solcx. Leave the managed path/version as-is unless you
# intentionally want a different local compiler cache.
